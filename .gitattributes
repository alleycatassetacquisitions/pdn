# Enforce LF line endings for all text files across all platforms.
* text=auto eol=lf

# Explicitly mark source and config files as text with LF.
*.cpp text eol=lf
*.hpp text eol=lf
*.h   text eol=lf
*.c   text eol=lf
*.ini text eol=lf
*.json text eol=lf
*.md  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
*.py  text eol=lf
*.sh  text eol=lf

# Treat binary files as binary (no line-ending conversion).
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.bin binary
*.elf binary
